# Copy this file to .env and fill in your values
# cp .env.example .env

# Django
SECRET_KEY=django-insecure-replace-with-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=ai_song_generation_platform
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Redis/Celery Broker
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AI Generator Strategy (Options: mock, suno)
GENERATOR_STRATEGY=mock

# Suno API Settings (if GENERATOR_STRATEGY=suno)
SUNO_API_KEY=your_suno_api_key_here

# Google OAuth (Required for Social Login)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
